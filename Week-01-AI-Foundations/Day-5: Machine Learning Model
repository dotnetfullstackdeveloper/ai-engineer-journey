Part 1 – Install & Import

import pandas as pd
import matplotlib.pyplot as plt
from sklearn.linear_model import LinearRegression

Part 2 – Create Simple Dataset

data = {
"Hours": [1, 2, 3, 4, 5],
"Marks": [40, 50, 60, 70, 80]
}
df = pd.DataFrame(data)

Part 3 – Prepare Data

X = df[["Hours"]]   # input (must be 2D)
y = df["Marks"]     # output

Part 4 – Train Model

model = LinearRegression()
model.fit(X, y)

Part 5 – Predict

new_data = pd.DataFrame({"Hours": [6]}) #Used DataFrame while predicting - to vaoid warning
prediction = model.predict(new_data)
print("Predicted Marks:", prediction)

Part 6 – Visualize Model

plt.scatter(df["Hours"], df["Marks"])
plt.plot(df["Hours"], model.predict(X))
plt.xlabel("Hours")
plt.ylabel("Marks")
plt.title("Study Hours vs Marks")
plt.show()

